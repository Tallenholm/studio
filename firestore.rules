
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write to any collection.
    // This is a permissive rule for internal applications where all users are trusted.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
