
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======== HELPER FUNCTIONS ========
    
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isOwner() {
      return request.auth != null && getUserRole(request.auth.uid) == 'owner';
    }
    
    function isManager() {
      return request.auth != null && getUserRole(request.auth.uid) == 'manager';
    }
    
    function isEmployee() {
      return request.auth != null && getUserRole(request.auth.uid) == 'employee';
    }

    function isAdmin() {
      return isOwner() || isManager();
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwnerOf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ======== COLLECTION RULES ========

    // --- Users ---
    // Admins can list all users. Users can only get their own profile. Owners can write.
    match /users/{userId} {
      allow get: if isAdmin() || isOwnerOf(userId);
      allow list: if isAdmin();
      allow write: if isOwner();
    }

    // --- Jobs, Clients, Rentals, Routes ---
    // Core operational data managed by admins. All employees can read jobs and routes.
    match /jobs/{jobId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /clients/{clientId} {
      allow get, list: if isAdmin();
      allow write: if isOwner();
    }
    match /rentals/{rentalId} {
        allow get, list: if isOwner();
        allow write: if isOwner();
    }
    match /snowRoutes/{routeId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    // --- Employee Submissions (Inspections, Expenses, Tasks, Time Off) ---
    // Employees can create. Admins can read/update. Employees can only read/list their own.
    match /inspectionReports/{reportId} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /expenseReports/{reportId} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    match /tasks/{taskId} {
      allow create: if isAdmin();
      allow get: if isAdmin() || resource.data.assignedToEmployeeId == request.auth.uid;
      allow update: if isAdmin() || resource.data.assignedToEmployeeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /timeOffRequests/{requestId} {
       allow create: if isSignedIn();
       allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
       allow update: if isAdmin();
       allow delete: if isAdmin();
    }
    
    // --- Fleet, Inventory, Documents, Work Orders, Maintenance ---
    // Managed by Admins, viewable by all.
    match /fleetAssets/{assetId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /inventory/{itemId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /documents/{docId} {
        allow write: if isAdmin();
        allow get: if isAdmin() || (resource.data.documentType == 'general' && isSignedIn()) || (resource.data.employeeId != null && resource.data.employeeId == request.auth.uid);
    }
    
    match /workOrders/{orderId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    match /maintenanceLogs/{logId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /violations/{violationId} {
        allow create: if isAdmin();
        allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
        allow delete: if isAdmin();
    }

    // --- AI Cache ---
    // Writable by server-side flows (admins), readable by admins for debugging.
    match /maintenanceScheduleSuggestions/{cacheKey} {
        allow get, list, write: if isAdmin();
    }

    // --- Notifications & Calendar ---
    // Calendar events are public reads for all signed-in users.
    // Notifications are readable by their recipient or 'all'.
    match /calendarEvents/{eventId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow write: if isAdmin();
      allow get: if isSignedIn() && (resource.data.recipientId == 'all' || resource.data.recipientId == request.auth.uid || isAdmin());
    }

    // User-specific settings (e.g., theme, notifications).
    // Each user can only read/write their own settings document.
    match /settings/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
