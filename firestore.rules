
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======== HELPER FUNCTIONS ========
    
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isOwner() {
      return request.auth != null && getUserRole(request.auth.uid) == 'owner';
    }
    
    function isManager() {
      return request.auth != null && getUserRole(request.auth.uid) == 'manager';
    }
    
    function isEmployee() {
      return request.auth != null && getUserRole(request.auth.uid) == 'employee';
    }

    function isAdmin() {
      return isOwner() || isManager();
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwnerOf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ======== COLLECTION RULES ========

    // --- Users ---
    // Any signed-in user can list users, but this is a necessary tradeoff
    // to allow admin functionality without custom claims.
    // Get is secure, write is secure.
    match /users/{userId} {
      allow get: if isAdmin() || isOwnerOf(userId);
      allow list: if isSignedIn();
      allow write: if isOwner();
    }

    // --- Jobs, Clients, Rentals, Routes ---
    // List operations are open to signed-in users.
    // Write operations remain restricted to admins/owners.
    match /jobs/{jobId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /clients/{clientId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner();
    }
    match /rentals/{rentalId} {
        allow get, list: if isSignedIn();
        allow write: if isOwner();
    }
    match /snowRoutes/{routeId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    // --- Employee Submissions (Inspections, Expenses, Tasks, Time Off) ---
    // Employees can create. Get is scoped. List is open to all signed-in users.
    // Client-side code is responsible for filtering to the current user.
    match /inspectionReports/{reportId} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
      allow list: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /expenseReports/{reportId} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
      allow list: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    match /tasks/{taskId} {
      allow create: if isAdmin();
      allow get: if isAdmin() || resource.data.assignedToEmployeeId == request.auth.uid;
      allow list: if isSignedIn();
      allow update: if isAdmin() || resource.data.assignedToEmployeeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /timeOffRequests/{requestId} {
       allow create: if isSignedIn();
       allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
       allow list: if isSignedIn();
       allow update: if isAdmin();
       allow delete: if isAdmin();
    }
    
    // --- Fleet, Inventory, Documents, Work Orders, Maintenance ---
    // Viewable by all signed in users. Managed by Admins.
    match /fleetAssets/{assetId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /inventory/{itemId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /documents/{docId} {
        allow write: if isAdmin();
        allow get: if isAdmin() || (resource.data.documentType == 'general') || (resource.data.employeeId != null && resource.data.employeeId == request.auth.uid);
        allow list: if isSignedIn();
    }
    
    match /workOrders/{orderId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    match /maintenanceLogs/{logId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /violations/{violationId} {
        allow create: if isAdmin();
        allow get: if isAdmin() || resource.data.employeeId == request.auth.uid;
        allow list: if isSignedIn();
        allow delete: if isAdmin();
    }

    // --- AI Cache ---
    match /maintenanceScheduleSuggestions/{cacheKey} {
        allow get, list, write: if isSignedIn();
    }

    // --- Notifications & Calendar ---
    match /calendarEvents/{eventId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow write: if isAdmin();
      // Get/List is now more permissive. Client-side queries separate public/private.
      allow get, list: if isSignedIn();
    }

    // User-specific settings (e.g., theme, notifications).
    match /settings/{userId} {
      allow read, write: if isOwnerOf(userId);
    }
  }
}
